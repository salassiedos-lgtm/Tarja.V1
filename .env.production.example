# ─────────────────────────────────────────────────────────────
# Variables de producción TARJA V.1
# En Coolify: copiar estas claves en Environment Variables del recurso.
# En local: copiar a `.env` (docker compose lo lee automáticamente).
# ─────────────────────────────────────────────────────────────

# --- Base de datos (Postgres) ---
POSTGRES_USER=tarja
POSTGRES_PASSWORD=cambia-esta-password-fuerte
POSTGRES_DB=tarja

# --- Secretos JWT (genera cada uno con: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-largo-y-aleatorio
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- URLs públicas ---
# URL pública del frontend (CORS del backend). Sin barra final.
FRONTEND_ORIGIN=https://tarja.tudominio.com
# URL pública del backend/API que el navegador usará (HTTP + WebSocket). Sin barra final.
# ⚠️ Es build-time: si la cambias, hay que RECONSTRUIR el frontend.
NEXT_PUBLIC_API_URL=https://api.tarja.tudominio.com

# --- Para probar en LOCAL usa en su lugar: ---
# FRONTEND_ORIGIN=http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3000
